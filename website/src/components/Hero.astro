---
---
<section class="hero-scene" id="hero">
  <div class="hero-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center px-6 pt-24 pb-20">
    <div class="reveal-up mb-6">
      <span class="section-tag">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Live Signals &middot; Free Forever
      </span>
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tighter mb-6">
      <span class="reveal-up block">Institutional</span>
      <span class="stat-value reveal-up block">Precision</span>
      <span class="text-white/40 text-3xl md:text-5xl reveal-up block">Delivered to Telegram</span>
    </h1>

    <p class="text-lg text-white/50 max-w-2xl mx-auto mb-10 leading-relaxed reveal-up">
      12-layer signal pipeline. SMC 8-Gate strategy. 20+ years backtested across 8 forex pairs.
      TradeKnox delivers institutional-quality signals with surgical precision.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal-up">
      <a href="https://t.me/TradeKnoxTestBot" class="btn-gold text-base">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Start Receiving Signals
      </a>
      <a href="#performance" class="btn-ghost text-base">
        View Backtest Results
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="mt-12 flex items-center justify-center gap-6 text-xs text-white/30 reveal-up">
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        1% Risk Per Trade
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        Instant Delivery
      </span>
      <span class="flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        No API Keys Required
      </span>
    </div>
  </div>
</section>
