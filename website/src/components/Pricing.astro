---
const FEATURES_LIST = [
  'Unlimited signals across 8 pairs',
  'SMC 8-Gate + False Breakout strategies',
  'Instant Telegram delivery',
  '3 TP levels with trailing',
  'London & New York session filtering',
  'Real-time regime detection',
];
---
<section id="pricing" class="py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="reveal-up mb-4">
      <span class="section-tag">Pricing</span>
    </div>
    <h2 class="section-heading mb-3 reveal-up">100% Free</h2>
    <p class="section-sub mx-auto mb-12 reveal-up">No subscription. No hidden fees. No API keys. Just connect and receive signals.</p>

    <div class="gradient-card pricing-featured max-w-lg mx-auto reveal-scale">
      <div class="gradient-card-inner text-center">
        <div class="text-sm text-[var(--gold)] font-semibold uppercase tracking-wider mb-2">TradeKnox Bot</div>
        <div class="text-4xl font-bold text-white mb-1">$0</div>
        <div class="text-sm text-white/40 mb-8">Free forever</div>
        <div class="space-y-3 text-left mb-8">
          {FEATURES_LIST.map((f, i) => (
            <div class="flex items-center gap-3">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--emerald)" stroke-width="2.5" class="flex-shrink-0"><path d="M20 6L9 17l-5-5"/></svg>
              <span class="text-sm text-white/70">{f}</span>
            </div>
          ))}
        </div>
        <a href="https://t.me/TradeKnoxTestBot" class="btn-gold w-full block text-center">
          Start Now — It's Free
        </a>
      </div>
    </div>
  </div>
</section>
